{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true
  },
  "include": [
    "src/ui/**/*",
    "src/ui/**/*.svelte",
    "src/types.d.ts"
  ],
  "exclude": [
    "node_modules/**/*",
    "dist/**/*"
  ]
}