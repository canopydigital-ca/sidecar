{
  "name": "chatgpt-dock",
  "version": "0.5.67",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "copy:assets": "bun run scripts/copy-assets.js",
    "update:pets": "bun run scripts/update-pets.ts",
    "build": "bun run scripts/build-orchestrator.js --production",
    "dev": "bun run scripts/build-orchestrator.js --dev",
    "build:main": "vite build -c vite.content.config.ts --mode production",
    "build:background": "bun build src/background/index.ts --outdir dist --target=browser --format=esm --naming background.js",
    "dev:main": "vite build -c vite.content.config.ts --mode development --watch",
    "build:ui": "vite build",
    "dev:ui": "vite build --watch",
    "typecheck:ui": "bunx tsc -p tsconfig.ui.json --noEmit && svelte-check --tsconfig ./tsconfig.ui.json",
    "verify:bundle": "bun run scripts/assert-prod-bundle.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "bun run test:unit && bun run test:e2e",
    "build:legacy": "bun build src/entrypoints/content.ts --outdir dist --target=browser --format=iife --sourcemap --define:__DEV__=false --define:process.env.NODE_ENV='\"production\"' --minify",
    "dev:legacy": "bun build src/entrypoints/content.ts --outdir dist --target=browser --format=iife --sourcemap --watch --define:__DEV__=true --define:process.env.NODE_ENV='\"development\"'"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/adm-zip": "^0.5.7",
    "@types/chrome": "^0.0.260",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.24",
    "bun-types": "latest",
    "concurrently": "^9.2.1",
    "jsdom": "^27.4.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "svelte": "5",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
